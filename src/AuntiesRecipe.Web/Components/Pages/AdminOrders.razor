@page "/admin/orders"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]

@using AuntiesRecipe.Application.Abstractions
@using AuntiesRecipe.Application.Orders
@using Microsoft.AspNetCore.Authorization

@inject IOrderService OrderService

<PageTitle>Admin orders</PageTitle>

<div class="simple-page-header menu-hero-header page-hero-header">
    <h1 class="mb-2">Admin Orders</h1>
    <p class="text-muted mb-0">Track incoming orders and pickup details.</p>
</div>

<ul class="nav nav-pills mb-3">
    <li class="nav-item">
        <button type="button" class='@GetTabClass("active")' @onclick='() => ChangeMainTabAsync("active")'>Current Orders</button>
    </li>
    <li class="nav-item ms-2">
        <button type="button" class='@GetTabClass("history")' @onclick='() => ChangeMainTabAsync("history")'>Order History</button>
    </li>
</ul>

@if (_loading)
{
    <p>Loading orders…</p>
}
else if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    @if (_mainTab == "active")
    {
        <ul class="nav nav-tabs mb-3">
            <li class="nav-item">
                <button type="button" class='@GetStatusClass("todo")' @onclick='() => ChangeStatusTabAsync("todo")'>To Do</button>
            </li>
            <li class="nav-item">
                <button type="button" class='@GetStatusClass("inprogress")' @onclick='() => ChangeStatusTabAsync("inprogress")'>In Progress</button>
            </li>
            <li class="nav-item">
                <button type="button" class='@GetStatusClass("completed")' @onclick='() => ChangeStatusTabAsync("completed")'>Completed</button>
            </li>
        </ul>

        @if (_orders.Count == 0)
        {
            <div class="alert alert-secondary">No orders in this bucket.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped align-middle">
                    <thead>
                        <tr>
                            <th>Order #</th>
                            <th>Token</th>
                            <th>Created (UTC)</th>
                            <th>Pickup</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in _orders)
                        {
                            <tr>
                                <td>@o.OrderId</td>
                                <td>#@o.DailyTokenNumber</td>
                                <td>@o.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@o.PickupName (@o.PickupPhone)</td>
                                <td>@o.Total.ToString("C")</td>
                                <td>
                                    <span class="badge text-bg-secondary">@o.Status</span>
                                </td>
                                <td>
                                    <select class="form-select form-select-sm" value="@o.Status" @onchange="(e) => ChangeOrderStatusAsync(o.OrderId, e.Value?.ToString())">
                                        @foreach (var option in _statusOptions)
                                        {
                                            <option value="@option">@option</option>
                                        }
                                    </select>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
    else
    {
        <div class="card simple-card mb-3">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Name</label>
                        <InputText class="form-control" @bind-Value="_historyFilter.PickupName" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Phone</label>
                        <InputText class="form-control" @bind-Value="_historyFilter.PickupPhone" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Token #</label>
                        <InputNumber class="form-control" @bind-Value="_historyFilter.TokenNumber" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">From</label>
                        <InputDate class="form-control" @bind-Value="_historyFilter.FromDateUtc" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">To</label>
                        <InputDate class="form-control" @bind-Value="_historyFilter.ToDateUtc" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Status</label>
                        <InputSelect class="form-select" @bind-Value="_historyFilter.Status">
                            <option value="">All</option>
                            @foreach (var option in _statusOptions)
                            {
                                <option value="@option">@option</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Page</label>
                        <InputNumber class="form-control" @bind-Value="_historyFilter.Page" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Page size</label>
                        <InputSelect class="form-select" @bind-Value="_historyFilter.PageSize">
                            <option value="25">25</option>
                            <option value="50">50</option>
                            <option value="100">100</option>
                        </InputSelect>
                    </div>
                    <div class="col-12">
                        <button class="btn btn-success me-2" type="button" @onclick="ApplyHistoryFiltersAsync">Apply Filters</button>
                        <button class="btn btn-outline-success" type="button" @onclick="ResetHistoryFiltersAsync">Reset</button>
                    </div>
                </div>
            </div>
        </div>

        @if (_orders.Count == 0)
        {
            <div class="alert alert-secondary">No history orders found for these filters.</div>
        }
        else
        {
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="small text-muted">
                    Showing @GetRangeStart()-@GetRangeEnd() of @_historyTotalCount
                </div>
                <div class="small text-muted">
                    Page @_historyFilter.Page of @(_historyTotalPages == 0 ? 1 : _historyTotalPages)
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-striped align-middle">
                    <thead>
                        <tr>
                            <th>Order #</th>
                            <th>Token</th>
                            <th>Created (UTC)</th>
                            <th>Pickup Name</th>
                            <th>Phone</th>
                            <th>Total</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in _orders)
                        {
                            <tr>
                                <td>@o.OrderId</td>
                                <td>#@o.DailyTokenNumber</td>
                                <td>@o.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@o.PickupName</td>
                                <td>@o.PickupPhone</td>
                                <td>@o.Total.ToString("C")</td>
                                <td>@o.Status</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="d-flex gap-2 justify-content-end mt-2">
                <button class="btn btn-outline-success btn-sm" type="button" disabled="@(_historyFilter.Page <= 1)" @onclick="PreviousHistoryPageAsync">Previous</button>
                <button class="btn btn-outline-success btn-sm" type="button" disabled="@(_historyFilter.Page >= _historyTotalPages)" @onclick="NextHistoryPageAsync">Next</button>
            </div>
        }
    }
}

@code {
    private bool _loading = true;
    private string? _error;
    private IReadOnlyList<OrderSummaryDto> _orders = Array.Empty<OrderSummaryDto>();
    private int _historyTotalCount;
    private int _historyTotalPages;
    private string _mainTab = "active";
    private string _statusTab = "todo";
    private readonly string[] _statusOptions = ["Placed", "Preparing", "ReadyForPickup", "Completed", "Cancelled"];
    private HistoryFilterModel _historyFilter = new();

    private sealed class HistoryFilterModel
    {
        public string? PickupName { get; set; }
        public string? PickupPhone { get; set; }
        public int? TokenNumber { get; set; }
        public DateTime? FromDateUtc { get; set; }
        public DateTime? ToDateUtc { get; set; }
        public string? Status { get; set; }
        public int Page { get; set; } = 1;
        public int PageSize { get; set; } = 50;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadOrdersAsync();
    }

    private async Task ChangeMainTabAsync(string tab)
    {
        _mainTab = tab;
        await LoadOrdersAsync();
    }

    private async Task ChangeStatusTabAsync(string tab)
    {
        _statusTab = tab;
        await LoadOrdersAsync();
    }

    private async Task ApplyHistoryFiltersAsync()
    {
        _mainTab = "history";
        _historyFilter.Page = 1;
        await LoadOrdersAsync();
    }

    private async Task ResetHistoryFiltersAsync()
    {
        _historyFilter = new HistoryFilterModel();
        _historyTotalCount = 0;
        _historyTotalPages = 0;
        await LoadOrdersAsync();
    }

    private async Task PreviousHistoryPageAsync()
    {
        if (_historyFilter.Page <= 1)
        {
            return;
        }

        _historyFilter.Page -= 1;
        await LoadOrdersAsync();
    }

    private async Task NextHistoryPageAsync()
    {
        if (_historyFilter.Page >= _historyTotalPages)
        {
            return;
        }

        _historyFilter.Page += 1;
        await LoadOrdersAsync();
    }

    private async Task ChangeOrderStatusAsync(int orderId, string? nextStatus)
    {
        if (string.IsNullOrWhiteSpace(nextStatus))
        {
            return;
        }

        try
        {
            await OrderService.UpdateOrderStatusAsync(orderId, nextStatus);
            await LoadOrdersAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task LoadOrdersAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            if (_mainTab == "history")
            {
                var history = await OrderService.GetOrderHistoryForAdminAsync(new AdminOrderHistoryFilterDto(
                    _historyFilter.PickupName,
                    _historyFilter.PickupPhone,
                    _historyFilter.TokenNumber,
                    _historyFilter.FromDateUtc,
                    _historyFilter.ToDateUtc,
                    _historyFilter.Status,
                    _historyFilter.Page,
                    _historyFilter.PageSize));
                _orders = history.Items;
                _historyTotalCount = history.TotalCount;
                _historyTotalPages = history.TotalPages;
                _historyFilter.Page = history.Page;
            }
            else
            {
                _orders = await OrderService.GetOrdersByStatusForAdminAsync(_statusTab);
                _historyTotalCount = 0;
                _historyTotalPages = 0;
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private string GetTabClass(string tab) => tab == _mainTab ? "btn btn-success" : "btn btn-outline-success";
    private string GetStatusClass(string tab) => tab == _statusTab ? "nav-link active" : "nav-link";
    private int GetRangeStart() => _historyTotalCount == 0 ? 0 : ((_historyFilter.Page - 1) * _historyFilter.PageSize) + 1;
    private int GetRangeEnd() => Math.Min(_historyTotalCount, _historyFilter.Page * _historyFilter.PageSize);
}
