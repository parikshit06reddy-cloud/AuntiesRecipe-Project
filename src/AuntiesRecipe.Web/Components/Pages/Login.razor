@page "/login"
@inject NavigationManager Navigation

<PageTitle>Login</PageTitle>

<div class="row justify-content-center mt-4 auth-wrap">
    <div class="col-12 col-sm-10 col-md-7 col-lg-5 col-xl-4">
        <div class="card simple-card auth-card">
            <div class="card-body">
                <h1 class="h2 mb-3 text-center">Login</h1>
                <p class="text-center text-muted small mb-4">Welcome back to Aunties Recipe</p>

                @if (_showError)
                {
                    <div class="alert alert-danger">Invalid username/email or password.</div>
                }

                <form method="post" action="/api/auth/login">
                    <input type="hidden" name="returnUrl" value="/" />

                    <div class="mb-3">
                        <label class="form-label">Username or Email</label>
                        <input class="form-control" type="text" name="usernameOrEmail" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input class="form-control" type="password" name="password" />
                    </div>

                    <button class="btn btn-primary w-100" type="submit">Sign in</button>
                </form>

                <p class="mt-3 text-muted mb-0 text-center">
                    Registration is currently disabled.
                </p>
            </div>
        </div>
    </div>
</div>

@code {
    private bool _showError;

    protected override void OnInitialized()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        _showError = uri.Query.Contains("error=1", StringComparison.OrdinalIgnoreCase);
    }
}
