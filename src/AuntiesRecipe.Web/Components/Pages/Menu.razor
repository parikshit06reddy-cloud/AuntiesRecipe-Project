@page "/menu"
@rendermode InteractiveServer
@using AuntiesRecipe.Application.Abstractions
@using AuntiesRecipe.Application.Cart
@using AuntiesRecipe.Application.Menu
@using AuntiesRecipe.Web.Services

@inject IMenuService MenuService
@inject ICartService CartService
@inject CartSessionService CartSession

@code {
    private const decimal DailySpecialPrice = 7.99m;
    private const string TodayOfferBadgeText = "Today's Offer";
    private const string JuicesCategoryName = "Featured Elixirs & Juices";

    private bool _loading = true;
    private string? _error;
    private IReadOnlyList<CategoryMenuDto> _menu = Array.Empty<CategoryMenuDto>();

    private int _todaySpecialItemId;

    private string? _message;

    private async Task AddToCartAsync(int menuItemId)
    {
        try
        {
            _message = null;
            var cartId = CartSession.GetOrCreateCartId();
            await CartService.AddToCartAsync(cartId, menuItemId, quantity: 1);
            _message = "Added to cart. Go to Cart to review.";
        }
        catch (Exception ex)
        {
            _message = ex.Message;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _menu = await MenuService.GetMenuAsync();

            var juices = _menu
                .FirstOrDefault(c => string.Equals(c.Name, JuicesCategoryName, StringComparison.OrdinalIgnoreCase))
                ?.Items
                .OrderBy(i => i.Id)
                .ToList()
                ?? new List<MenuItemDto>();

            var flat = juices.Count > 0
                ? juices
                : _menu.SelectMany(c => c.Items).OrderBy(i => i.Id).ToList();
            if (flat.Count > 0)
            {
                var idx = DateTime.UtcNow.DayOfYear % flat.Count;
                _todaySpecialItemId = flat[idx].Id;
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private bool IsTodaySpecial(MenuItemDto item) => item.Id == _todaySpecialItemId;
}

<PageTitle>Aunties Recipe — Menu</PageTitle>

@if (_loading)
{
    <div class="alert alert-light border">Loading menu...</div>
}
else if (_error is not null)
{
    <p class="text-danger">@_error</p>
}
else
{
    <div class="menu-layout">
        <aside class="menu-sidebar simple-card">
            <div class="menu-sidebar-header">Menu Categories</div>
            <div class="menu-sidebar-links">
                @foreach (var cat in _menu)
                {
                    <a href="@($"/menu#cat-{cat.Id}")" class="menu-sidebar-link">@cat.Name</a>
                }
            </div>
        </aside>

        <div class="menu-main">
            <div class="simple-page-header menu-hero-header page-hero-header">
                <h1 class="mb-2">Menu</h1>
                <p class="text-muted mb-0">Explore cookies, juices, fruit salads, combos, and special offers. One juice item per day is a special at $7.99.</p>
            </div>

            @foreach (var cat in _menu)
            {
                <section class="mb-5 menu-section" id="@($"cat-{cat.Id}")">
                    <h2 class="h4 border-bottom pb-2 mb-3 menu-category-title">@cat.Name</h2>
                    <div class="row g-3">
                        @foreach (var item in cat.Items)
                        {
                            <div class="col-md-6 col-xl-4">
                                <article class="card h-100 simple-card menu-item-card">
                                    @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" class="card-img-top" alt="@item.Name" style="height: 180px; object-fit: cover;" loading="lazy" />
                                    }
                                    <div class="card-body d-flex flex-column">
                                        <div class="d-flex justify-content-between align-items-start gap-2 mb-1">
                                            <h3 class="h6 mb-0 menu-item-name">@item.Name</h3>
                                            @if (IsTodaySpecial(item))
                                            {
                                                <span class="badge text-bg-danger">@TodayOfferBadgeText</span>
                                            }
                                        </div>

                                        @if (IsTodaySpecial(item))
                                        {
                                            <div class="mb-2">
                                                <span class="text-muted me-1"><s>@item.Price.ToString("C")</s></span>
                                                <span class="fw-semibold text-danger">@DailySpecialPrice.ToString("C")</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="mb-2 fw-semibold menu-item-price">@item.Price.ToString("C")</div>
                                        }

                                        @if (!string.IsNullOrWhiteSpace(item.Description))
                                        {
                                            <p class="small text-muted mb-3 menu-item-desc">@item.Description</p>
                                        }

                                        <button class="btn btn-primary btn-sm mt-auto" @onclick="() => AddToCartAsync(item.Id)" type="button">
                                            Add to cart
                                        </button>
                                    </div>
                                </article>
                            </div>
                        }
                    </div>
                </section>
            }
        </div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div class="alert alert-info mt-3">@_message</div>
}
